{
  "name": "pi-web",
  "version": "0.0.1",
  "description": "Pi extension: vendor-agnostic web_search and web_fetch (Exa via exa-js)",
  "keywords": [
    "exa",
    "pi-extension",
    "pi-package",
    "web-search"
  ],
  "license": "MIT",
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "oxlint src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test"
  },
  "dependencies": {
    "effect": "4.0.0-beta.59",
    "exa-js": "^2.8.0",
    "parallel-web": "^0.5.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.75.4",
    "@earendil-works/pi-coding-agent": "0.75.4",
    "@earendil-works/pi-tui": "0.75.4",
    "@effect/vitest": "4.0.0-beta.59",
    "@types/node": "^25.0.0",
    "typebox": "1.1.38",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
